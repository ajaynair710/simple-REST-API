# --- Option A: full URI (e.g. Aiven "Service URI" from the console) ---
# Include the password: postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
# DATABASE_URL=postgres://avnadmin:YOUR_PASSWORD@your-host.aivencloud.com:20178/defaultdb?sslmode=require

# --- Option B: separate variables (set DB_SSL=true for Aiven / cloud Postgres) ---
DB_HOST=your-host.aivencloud.com
DB_PORT=20178
DB_USER=avnadmin
DB_PASSWORD=YOUR_PASSWORD
DB_NAME=defaultdb
DB_SSL=true

# Aiven / TLS: if you see SELF_SIGNED_CERT_IN_CHAIN, download ca.pem from the Aiven console and set:
# PGSSLROOTCERT=./certs/ca.pem
# Or paste the PEM (use \n for newlines in a single line):
# DATABASE_SSL_CA="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
#
# Dev only (insecure — do not use in production):
# DB_SSL_REJECT_UNAUTHORIZED=false

# App
# PORT=3000
